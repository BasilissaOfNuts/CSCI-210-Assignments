flowchart LR
    %% Styles
    classDef pk fill:#f96,stroke:#333,stroke-width:2px,color:#000
    classDef composite fill:#fff4dd,stroke:#d4a017,stroke-width:2px,color:#000
    classDef attr fill:#fff,stroke:#333,stroke-width:1px

    subgraph CUSTOMER_Table [CUSTOMER]
        C1[CUS_ID]:::pk --> C2[FNAME]
        C1 --> C3[LNAME]
        C1 --> C4[EMAIL]
        C1 --> C5[PHONE_NUM]
        C1 --> C6[STREET]
        C1 --> C7[CITY]
        C1 --> C8[ZIP_CODE]
    end

    subgraph ORDER_Table [ORDER]
        O1[ORD_ID]:::pk --> O2[CUS_ID FK]
        O1 --> O3[TYPE]
        O1 --> O4[ORD_SPLIT]
        O1 --> O5[ORD_TIME]
        O1 --> O6[TABLE_NUM]
    end

    subgraph ORDER_LINE_ITEM_Table [ORDER_LINE_ITEM]
        direction TB
        OLI_PK[ORD_ID + LINE_NUM]:::composite
        OLI_PK --> OLI1[DISH_ID FK]
        OLI_PK --> OLI2[SPLIT_ID FK]
        OLI_PK --> OLI3[QUANTITY]
        OLI_PK --> OLI4[PRICE]
        OLI_PK --> OLI5[NOTES]
    end

    subgraph INVOICE_Table [INVOICE]
        INV_PK[ORD_ID + SPLIT_ID]:::composite
        INV_PK --> I1[PAY_TYPE]
        INV_PK --> I2[PAY_INFO]
        INV_PK --> I3[PAID]
        INV_PK --> I4[CREATE_TIME]
        INV_PK --> I5[PAID_TIME]
    end

    subgraph DISH_Table [DISH]
        D1[DISH_ID]:::pk --> D2[ZH_NAME / EN_NAME]
        D1 --> D3[PRICE]
        D1 --> D4[AVAILABLE]
        D1 --> D5[CATEGORY]
        D1 --> D6[ZH_DESC / EN_DESC]
    end

    subgraph ORDER_LINE_OPTION_Table [ORDER_LINE_OPTION]
        OLO_PK[ORD_ID + LINE_NUM + OPT_ID]:::composite
        OLO_PK --> OLO1[QUANTITY]
        OLO_PK --> OLO2[PRICE]
        OLO_PK --> OLO3[NOTES]
    end